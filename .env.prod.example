# Registry e versao
REGISTRY=docker.io
NAMESPACE=docker 
APP_VERSION=latest

# Banco de dados
DB_HOST=localhost
DB_NAME=financeflow
DB_USER=financeflow
DB_PASSWORD=financeflow
DB_PORT=5432

# Backend
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
JWT_SECRET=ALTERAR_PARA_UM_SEGREDO_COM_32+_CARACTERES
JWT_REFRESH_SECRET=ALTERAR_PARA_UM_SEGREDO_COM_32+_CARACTERES
CORS_ALLOWED_ORIGINS=
FRONTEND_URL=

# Frontend
FRONTEND_PORT=8081
